{
  "name": "rainbowland",
  "version": "1.1.14",
  "private": true,
  "description": "Rainbow Land — Free live streaming studio built for LGBT+ creators",
  "author": {
    "name": "Common-joeAI",
    "email": "support@rainbowland.cc",
    "url": "https://rainbowland.cc"
  },
  "main": "electron/main.js",
  "homepage": "https://rainbowland.cc",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "release": "vite build && electron-builder --publish always",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.400.0",
    "react-player": "^2.16.0",
    "zustand": "^4.5.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "socket.io-client": "^4.7.2",
    "hls.js": "^1.5.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.3.1",
    "tailwindcss": "^3.4.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "cc.rainbowland.app",
    "productName": "Rainbow Land",
    "copyright": "Copyright © 2026 Rainbow Land",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "electron/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "electron/assets/icon.png",
      "category": "AudioVideo",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Rainbow Land"
    },
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "Common-joeAI",
      "repo": "rainbowland"
    }
  }
}
